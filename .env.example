# Facebook Page ID (single page — posts categorized by hashtag: #local, #regional, #national)
VITE_FACEBOOK_PAGE_ID=your_facebook_page_id

# Live Stream Configuration
VITE_LIVE_VIDEO_URL=
VITE_LIVE_AUDIO_URL=
VITE_IS_LIVE=false

# Supabase Configuration (Backend — anon key only, service_role is server-side)
VITE_SUPABASE_URL=your_supabase_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Monitoring (optional)
VITE_SENTRY_DSN=your_sentry_dsn
