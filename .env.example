# Facebook API Configuration
# Get these from https://developers.facebook.com
VITE_FACEBOOK_APP_ID=your_facebook_app_id
VITE_FACEBOOK_APP_SECRET=your_facebook_app_secret
VITE_FACEBOOK_GRAPH_API_VERSION=v25.0
VITE_FACEBOOK_ACCESS_TOKEN=your_facebook_access_token

# Facebook Page ID (same page for all categories — posts are filtered by hashtag)
VITE_FACEBOOK_LOCAL_PAGE_ID=your_page_id
VITE_FACEBOOK_REGIONAL_PAGE_ID=your_page_id
VITE_FACEBOOK_NATIONAL_PAGE_ID=your_page_id

# API Configuration
VITE_API_BASE_URL=https://graph.facebook.com
# Set to true to use Facebook API, false to use mock data
VITE_USE_FACEBOOK_API=true

# Live Stream Configuration
# Replace these with your actual stream URLs
VITE_LIVE_VIDEO_URL=
VITE_LIVE_AUDIO_URL=
# Set to true when the station is broadcasting live
VITE_IS_LIVE=false

# Supabase Configuration (Backend)
VITE_SUPABASE_URL=your_supabase_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
# NOTE: Service Role Key should NEVER be in frontend code.
# It is only used by server-side scripts (sync.js via GitHub Actions).
VITE_SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Monitoring (optional)
VITE_SENTRY_DSN=your_sentry_dsn
