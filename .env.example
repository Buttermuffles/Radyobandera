# Facebook API Configuration
# Get these from https://developers.facebook.com/apps/
VITE_FACEBOOK_APP_ID=your_new_app_id
VITE_FACEBOOK_APP_SECRET=your_new_app_secret
VITE_FACEBOOK_GRAPH_API_VERSION=v20.0
VITE_FACEBOOK_ACCESS_TOKEN=your_new_access_token

# Facebook Page IDs for News Categories
# Get these from your Facebook pages - right-click on page > Inspect > search for 'page_id'
VITE_FACEBOOK_LOCAL_PAGE_ID=your_local_page_id
VITE_FACEBOOK_REGIONAL_PAGE_ID=your_regional_page_id
VITE_FACEBOOK_NATIONAL_PAGE_ID=your_national_page_id

# API Configuration
VITE_API_BASE_URL=https://graph.facebook.com
# Set to false to use mock data instead of Facebook API
VITE_USE_FACEBOOK_API=true
